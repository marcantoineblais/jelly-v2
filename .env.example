# Ports (used by dev, start, and Docker)
# Next reads PORT automatically for "next start"
PORT=4000
SOCKET_SERVER_PORT=4001
FILE_SERVER_PORT=4002

# Exposed to the browser so the client connects to the right WebSocket port
NEXT_PUBLIC_SOCKET_SERVER_PORT=4001

# Optional: override config from env (e.g. when mounting folders in Docker)
# Comma-separated paths where downloads are scanned
# DOWNLOAD_PATHS=/mnt/downloads,/mnt/encode
# JSON array of libraries: name, path, type (show|movie)
# LIBRARIES_JSON=[{"name":"Shows","path":"/mnt/tv","type":"show"},{"name":"Movies","path":"/mnt/movies","type":"movie"}]
# Comma-separated video extensions including the dot
# VIDEOS_EXT=.mp4,.mkv

# Proton VPN WireGuard (for gluetun). Get from account.proton.me → Downloads → WireGuard config → PrivateKey in .conf
# WIREGUARD_PRIVATE_KEY=your-private-key-from-proton-conf
# SERVER_COUNTRIES=Canada

# Ports (processes listen on these inside the container / locally)
PORT=3000
QBITTORRENT_WEBUI_PORT=8080
JACKETT_PORT=9117
FLARESOLVERR_PORT=8191
SOCKET_SERVER_PORT=3000
FILE_SERVER_PORT=3000

# Service URLs – use your domains (no localhost). Required.
# App (Next.js) – where users open the app
APP_URL=https://example.com
NEXT_PUBLIC_APP_URL=https://example.com

# File server – where the Next API sends file jobs (server-side)
FILE_SERVER_URL=https://files.example.com

# Socket server – WebSocket for live progress
# Used by file-server to connect (server-side)
SOCKET_SERVER_WS_URL=wss://socket.example.com
# Used by the browser to connect (must be set)
NEXT_PUBLIC_SOCKET_SERVER_URL=wss://socket.example.com

# qBittorrent Web API (for /api/qbit/* routes). In Docker with gluetun, use http://jelly-gluetun:<QBITTORRENT_WEBUI_PORT>
QBIT_URL=http://jelly-gluetun:8080
QBIT_USER=admin
QBIT_PASS=password

# Jackett (torrent indexer proxy) for /api/torrents/feed search. In Docker with gluetun, use http://jelly-gluetun:9117 (or JACKETT_PORT if changed)
# Get the API key from Jackett UI (top right). Add indexers in Jackett, then search from the Torrents page.
# In Jackett UI, set FlareSolverr URL to http://127.0.0.1:8191 (or FLARESOLVERR_PORT; same network stack via gluetun).
JACKETT_URL=http://jelly-gluetun:9117
JACKETT_API_KEY=your-api-key-here

# Required for auth. Signs session cookies. Use a long random string.
JWT_SIGN_TOKEN=your-secure-random-token

# Auth: credentials file (created on first /setup). Or run: node scripts/hash-password.js "password"
AUTH_DATA_PATH=/data/auth/credentials.json

# Session: download filters, etc. One JSON file per user.
SESSION_DATA_PATH=/data/sessions

# Optional: override config from env (container paths when using Docker)
# DOWNLOAD_PATHS=/data/downloads,/data/encode
# LIBRARIES_JSON=[{"name":"Shows","path":"/data/tv","type":"show"},...]
# VIDEOS_EXT=.mp4,.mkv

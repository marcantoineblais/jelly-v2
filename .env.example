# Ports (used by dev, start, and Docker)
PORT=4000
SOCKET_SERVER_PORT=4001
FILE_SERVER_PORT=4002

# Service URLs (per machine: set hostname or reverse-proxy URL)
# Next API -> file-server (server-side). Docker same-host: http://file-server:4002
FILE_SERVER_URL=http://localhost:4002
# file-server -> socket-server (server-side). Docker same-host: ws://socket-server:4001
SOCKET_SERVER_WS_URL=ws://localhost:4001

# Public URLs (browser). Set to this machine's host or proxy (e.g. https://jelly.home, wss://jelly.home:4001)
NEXT_PUBLIC_APP_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_SERVER_URL=ws://localhost:4001

# Docker volume mounts (per machine). Host path -> container path is fixed in docker-compose.yml.
# Set these to where this machine mounts the network shares. No Node required on host.
# DOWNLOADS_PATH=/mnt/nas/downloads
# ENCODE_PATH=/mnt/nas/encode
# TV_SHOWS_PATH=/mnt/nas/tv
# MOVIES_PATH=/mnt/nas/movies
# ANIME_PATH=/mnt/nas/anime
# ANIME_MOVIES_PATH=/mnt/nas/anime-movies

# Optional: override config from env (use container paths /data/... when using Docker)
# DOWNLOAD_PATHS=/data/downloads,/data/encode
# LIBRARIES_JSON=[{"name":"Shows","path":"/data/tv","type":"show"},{"name":"Movies","path":"/data/movies","type":"movie"},{"name":"Animes","path":"/data/anime","type":"show"},{"name":"Anime movies","path":"/data/anime-movies","type":"movie"}]
# VIDEOS_EXT=.mp4,.mkv

# Copy this to .env when using docker-compose.dev.yml
# cp .env.dev .env
# Then set JACKETT_API_KEY from Jackett UI (http://localhost:9117)
# URLs use Docker service name + port (app runs inside the app container).

PORT=3000
APP_URL=http://app:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Jackett (required for Torrents page search)
JACKETT_URL=http://jackett:9117
JACKETT_API_KEY=

# Optional: only if you add these services to the dev stack (use service name + port)
SOCKET_SERVER_URL=ws://socket-server:3001
FILE_SERVER_URL=http://files-server:3002
QBIT_URL=http://qbittorrent:8080
QBIT_USER=admin
QBIT_PASS=password
